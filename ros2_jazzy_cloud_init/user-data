#cloud-config
# Ubuntu 24.04 LTS - Raspberry Pi 5
# Auto-instalacja ROS 2 Jazzy Jalisco przy pierwszym uruchomieniu

hostname: raspberrypi
manage_etc_hosts: true

# Domyslny uzytkownik Ubuntu (login: ubuntu, haslo: ubuntu)
# Zmien haslo przy pierwszym logowaniu!
chpasswd:
  expire: false

# Pakiety systemowe potrzebne do ROS 2
packages:
  - curl
  - gnupg
  - lsb-release
  - locales
  - software-properties-common
  - build-essential
  - git

package_update: true
package_upgrade: true

runcmd:
  # --- Ustawienie locale ---
  - locale-gen en_US en_US.UTF-8
  - update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8

  # --- Dodanie repozytorium ROS 2 ---
  - curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key -o /usr/share/keyrings/ros-archive-keyring.gpg
  - echo "deb [arch=arm64 signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu noble main" > /etc/apt/sources.list.d/ros2.list
  - apt-get update

  # --- Instalacja ROS 2 Jazzy (base + narzedzia) ---
  - apt-get install -y ros-jazzy-ros-base python3-argcomplete python3-colcon-common-extensions python3-rosdep ros-dev-tools

  # --- Inicjalizacja rosdep ---
  - rosdep init
  - rosdep update

  # --- Dodanie source do .bashrc uzytkownika ubuntu ---
  - echo "source /opt/ros/jazzy/setup.bash" >> /home/ubuntu/.bashrc
  - echo "source /opt/ros/jazzy/setup.bash" >> /root/.bashrc

  # --- Sygnalizacja zakonczenia instalacji ---
  - touch /home/ubuntu/ROS2_JAZZY_INSTALLED
  - echo "ROS 2 Jazzy installed successfully" > /home/ubuntu/ROS2_JAZZY_INSTALLED

final_message: |
  Raspberry Pi 5 gotowy!
  ROS 2 Jazzy zainstalowany.
  Zaloguj sie: ubuntu / ubuntu
  Zmien haslo komenda: passwd
